[Desktop Entry]
Type=Application
Name=TextSnatcher (with Tray Support)
Comment=Snatch Text with just a Drag - with tray icon support on Wayland
GenericName=TextSnatcher
Exec=env GDK_BACKEND=x11 com.github.rajsolai.textsnatcher %U
Icon=com.github.rajsolai.textsnatcher
Terminal=false
Categories=Graphics;Scanning;
Keywords=TextSnatcher;OCR;tray;wayland;